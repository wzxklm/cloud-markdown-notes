{
  "name": "cloud-markdown-notes-app",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud Markdown notes API, Web UI, and development workspace.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wzxklm/cloud-markdown-notes.git"
  },
  "bugs": {
    "url": "https://github.com/wzxklm/cloud-markdown-notes/issues"
  },
  "homepage": "https://github.com/wzxklm/cloud-markdown-notes#readme",
  "type": "module",
  "scripts": {
    "dev": "npm run migrate && concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "migrate": "tsx scripts/migrate.ts",
    "notes": "tsx src/cli/index.ts",
    "start": "npm run build && node dist-node/scripts/migrate.js && node dist-node/scripts/start-prod.js",
    "test": "sh tests/run-e2e.sh",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "tsc --noEmit && vite build && npm run build:server",
    "build:cli": "rm -rf packages/cli/dist && esbuild src/cli/index.ts --bundle --platform=node --format=esm --outfile=packages/cli/dist/index.js",
    "build:server": "rm -rf dist-node && esbuild src/server/index.ts scripts/migrate.ts scripts/serve-web.ts scripts/start-prod.ts --bundle --platform=node --format=esm --outdir=dist-node --outbase=. --packages=external"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fflate": "^0.8.3",
    "minimatch": "^10.2.5",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.16"
  }
}
